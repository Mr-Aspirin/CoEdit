<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.coedit.mapper.FolderMapper">

    <insert id="insert" parameterType="com.coedit.entity.Folder" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO folders (user_id, name, created_at)
        VALUES (#{userId}, #{name}, NOW())
    </insert>

    <update id="update" parameterType="com.coedit.entity.Folder">
        UPDATE folders
        SET name = #{name}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM folders WHERE id = #{id}
    </delete>

    <select id="findById" resultType="com.coedit.entity.Folder">
        SELECT * FROM folders WHERE id = #{id}
    </select>

    <select id="findByUserId" resultType="com.coedit.entity.Folder">
        SELECT * FROM folders WHERE user_id = #{userId} ORDER BY created_at ASC
    </select>

</mapper>
